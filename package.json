{
  "name": "second-brain-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:migrate": "wrangler d1 migrations apply second-brain --local",
    "db:migrate:remote": "wrangler d1 migrations apply second-brain --remote",
    "setup": "tsx scripts/setup.ts",
    "setup:dry": "tsx scripts/setup.ts --dry-run"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "@cloudflare/workers-types": "^4.20250620.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "wrangler": "^4.105.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0"
  },
  "allowScripts": {
    "esbuild@0.17.19": true,
    "esbuild@0.21.5": true,
    "sharp@0.33.5": true,
    "workerd@1.20241230.0": true,
    "workerd@1.20250718.0": true,
    "fsevents@2.3.3": true
  }
}
